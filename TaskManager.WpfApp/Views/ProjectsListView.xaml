<UserControl x:Class="TaskManager.WpfApp.Views.ProjectsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Проєкти"
                       FontSize="24"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Content="+ Новий проєкт"
                    Padding="14,8"
                    Background="#0E7C3A"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Command="{Binding AddProjectCommand}" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Padding="8,6"
                     VerticalContentAlignment="Center"
                     Background="#2D2D30"
                     Foreground="White"
                     BorderBrush="#3F3F46"
                     CaretBrush="White"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Пошук за назвою або типом" />
            <TextBlock Grid.Column="0"
                       Text="Пошук за назвою або типом..."
                       IsHitTestVisible="False"
                       Foreground="#777"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Grid.Column="1"
                       Text="Сортування:"
                       Margin="12,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="#AAA" />
            <ComboBox Grid.Column="2"
                      MinWidth="180"
                      ItemsSource="{Binding SortOptionsList}"
                      SelectedItem="{Binding SelectedSortOption}" />
        </Grid>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Projects}"
                 BorderThickness="1"
                 BorderBrush="#3F3F46"
                 Background="#1E1E1E"
                 Foreground="White"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Id, Mode=OneWay}"
                                           FontWeight="SemiBold"
                                           Foreground="#808080"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Name, Mode=OneWay}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="|" Foreground="#666" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Type, Mode=OneWay}" Foreground="#888" />
                            </StackPanel>
                            <TextBlock Margin="0,4,0,0" Foreground="#4EC9B0">
                                <Run Text="Прогрес: " />
                                <Run Text="{Binding ProgressPercent, StringFormat={}{0:F0}%, Mode=OneWay}" />
                                <Run Text=" | Завдань: " Foreground="#888" />
                                <Run Text="{Binding TotalTaskCount, Mode=OneWay}" Foreground="#888" />
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Відкрити"
                                    Padding="10,4"
                                    Margin="0,0,6,0"
                                    Background="#0E639C"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Command="{Binding DataContext.OpenProjectCommand,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                            <Button Content="Редагувати"
                                    Padding="10,4"
                                    Margin="0,0,6,0"
                                    Background="#6A4FBF"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Command="{Binding DataContext.EditProjectCommand,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                            <Button Content="Видалити"
                                    Padding="10,4"
                                    Background="#9B2C2C"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Command="{Binding DataContext.DeleteProjectCommand,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="12,10" />
                    <Setter Property="Margin" Value="0,0,0,4" />
                    <Setter Property="Background" Value="#2D2D30" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3E3E42" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <TextBlock Grid.Row="3"
                   Text="Проєктів не знайдено."
                   Foreground="#888"
                   Margin="0,12,0,0"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</UserControl>
