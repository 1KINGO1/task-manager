<UserControl x:Class="TaskManager.WpfApp.Views.TaskDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding TaskTitle}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Top"
                            Visibility="{Binding TaskExists, Converter={StaticResource BoolToVisibility}}">
                    <Button Content="Редагувати"
                            Padding="12,6"
                            Margin="0,0,6,0"
                            Background="#6A4FBF"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding EditCommand}" />
                    <Button Content="Видалити"
                            Padding="12,6"
                            Background="#9B2C2C"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding DeleteCommand}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Проєкт:" Foreground="#888" FontSize="12" />
                <TextBlock Text="{Binding ProjectName}" Margin="0,2,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="Пріоритет:" Foreground="#888" FontSize="12" />
                <TextBlock Text="{Binding Priority}" Margin="0,2,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,12">
                <TextBlock Text="Термін виконання:" Foreground="#888" FontSize="12" />
                <TextBlock Text="{Binding DueDate}" Margin="0,2,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,12">
                <TextBlock Text="Статус:" Foreground="#888" FontSize="12" />
                <TextBlock Text="{Binding StatusDisplay}" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#DDD" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                    <Setter Property="Foreground" Value="#4EC9B0" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                    <Setter Property="Foreground" Value="#F48771" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Row="5">
                <TextBlock Text="Опис:" Foreground="#888" FontSize="12" />
                <TextBlock Text="{Binding Description}"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
