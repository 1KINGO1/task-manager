<Page x:Class="TaskManager.WpfApp.Pages.ProjectDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Project Details">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="ProjectNameText" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock x:Name="ProjectTypeText" Foreground="#888" Margin="0,0,0,4" />
                <TextBlock x:Name="ProjectDescriptionText" TextWrapping="Wrap" Margin="0,0,0,8" />
                <TextBlock x:Name="ProjectProgressText" Foreground="#4EC9B0" FontWeight="SemiBold" />
            </StackPanel>

            <TextBlock Grid.Row="1" Text="Завдання" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

            <ListBox x:Name="TasksListBox"
                     Grid.Row="2"
                     BorderThickness="1"
                     BorderBrush="#3F3F46"
                     Background="#1E1E1E"
                     Foreground="White"
                     MaxHeight="300"
                     SelectionChanged="TasksListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Id, Mode=OneWay}" FontWeight="SemiBold" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding Title, Mode=OneWay}" Margin="0,0,8,0" />
                            <TextBlock Text="|" Foreground="#666" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding Priority, Mode=OneWay}" Foreground="#888" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding DueDate, StringFormat=yyyy-MM-dd, Mode=OneWay}" Foreground="#888" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding StatusDisplay, Mode=OneWay}" Margin="0,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#888" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Foreground" Value="#4EC9B0" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                <Setter Property="Foreground" Value="#F48771" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,8" />
                        <Setter Property="Margin" Value="0,0,0,2" />
                        <Setter Property="Background" Value="#2D2D30" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0E639C" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <TextBlock x:Name="NoTasksText"
                       Grid.Row="3"
                       Text="Завдань у цьому проєкті немає."
                       Foreground="#888"
                       Visibility="Collapsed"
                       Margin="0,12,0,0" />
        </Grid>
    </ScrollViewer>
</Page>
