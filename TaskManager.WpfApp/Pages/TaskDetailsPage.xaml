<Page x:Class="TaskManager.WpfApp.Pages.TaskDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Task Details">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TaskTitleText"
                       Grid.Row="0"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0,0,0,16" />

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="ID проєкту:" Foreground="#888" FontSize="12" />
                <TextBlock x:Name="ProjectIdText" Margin="0,2,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="Пріоритет:" Foreground="#888" FontSize="12" />
                <TextBlock x:Name="PriorityText" Margin="0,2,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,12">
                <TextBlock Text="Термін виконання:" Foreground="#888" FontSize="12" />
                <TextBlock x:Name="DueDateText" Margin="0,2,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,12">
                <TextBlock Text="Статус:" Foreground="#888" FontSize="12" />
                <TextBlock x:Name="StatusText" Margin="0,2,0,0" FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Row="5">
                <TextBlock Text="Опис:" Foreground="#888" FontSize="12" />
                <TextBlock x:Name="DescriptionText"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
