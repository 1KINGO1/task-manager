<Window x:Class="TaskManager.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskManager.WpfApp.ViewModels"
        xmlns:views="clr-namespace:TaskManager.WpfApp.Views"
        Title="{Binding Title}"
        Height="600"
        Width="800"
        MinHeight="400"
        MinWidth="600"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ProjectsListViewModel}">
            <views:ProjectsListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProjectDetailsViewModel}">
            <views:ProjectDetailsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskDetailsViewModel}">
            <views:TaskDetailsView />
        </DataTemplate>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Назад"
                        Padding="12,6"
                        Margin="0,0,8,0"
                        Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding GoBackCommand}" />
                <TextBlock Text="{Binding Title}"
                           VerticalAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White" />
            </StackPanel>
        </Border>

        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
