<Window x:Class="TaskManager.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskManager.WpfApp.ViewModels"
        xmlns:views="clr-namespace:TaskManager.WpfApp.Views"
        Title="{Binding Title}"
        Height="720"
        Width="1100"
        MinHeight="500"
        MinWidth="820"
        Background="#1B1B1F"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ProjectsListViewModel}">
            <views:ProjectsListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProjectDetailsViewModel}">
            <views:ProjectDetailsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProjectEditViewModel}">
            <views:ProjectEditView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskDetailsViewModel}">
            <views:TaskDetailsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskEditViewModel}">
            <views:TaskEditView />
        </DataTemplate>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" Padding="12,8" IsEnabled="{Binding IsNotBusy}">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Назад"
                        Padding="12,6"
                        Margin="0,0,8,0"
                        Background="#3E3E42"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding GoBackCommand}" />
                <TextBlock Text="{Binding Title}"
                           VerticalAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentViewModel}"
                            IsEnabled="{Binding IsNotBusy}" />

            <Grid Background="#B3000000"
                  Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                <Border Background="#2D2D30"
                        CornerRadius="6"
                        BorderBrush="#3F3F46"
                        BorderThickness="1"
                        Padding="22,16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ProgressBar IsIndeterminate="True"
                                     Width="140"
                                     Height="14"
                                     Margin="0,0,14,0"
                                     Foreground="#4EC9B0" />
                        <TextBlock Text="{Binding BusyMessage}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
